{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "name",
        "port",
        "protocol"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "port": {
            "type": "integer"
        },
        "protocol": {
            "type": "string",
            "enum": [
                "TCP",
                "UDP"
            ]
        },
        "targetPort": {
            "type": "string"
        }
    }
}
